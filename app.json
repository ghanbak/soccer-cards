{
  "expo": {
    "name": "Book 'Em",
    "slug": "soccer-cards",
    "scheme": "bookem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ghanbak.bookem",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/app.icon"
    },
    "android": {
      "package": "com.ghanbak.bookem",
      "adaptiveIcon": {
        "backgroundColor": "#FFFF00",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFF00",
          "image": "./assets/splash-logo.png",
          "imageWidth": 1
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "YellowCardWidget",
              "displayName": "Yellow Card",
              "description": "Tap to pull up a yellow card.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryRectangular"
              ]
            },
            {
              "name": "RedCardWidget",
              "displayName": "Red Card",
              "description": "Tap to pull up a red card.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "YellowCard",
              "label": "Yellow Card",
              "description": "Tap to pull up a yellow card.",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetCellWidth": 1,
              "targetCellHeight": 1,
              "resizeMode": "none"
            },
            {
              "name": "RedCard",
              "label": "Red Card",
              "description": "Tap to pull up a red card.",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetCellWidth": 1,
              "targetCellHeight": 1,
              "resizeMode": "none"
            }
          ]
        }
      ],
      "./plugins/withQuickSettingsTiles",
      "./plugins/withAppShortcuts"
    ],
    "extra": {
      "eas": {
        "projectId": "97e1d378-f388-4ea6-a534-e4090bca483c"
      }
    },
    "owner": "ghanbak"
  }
}
